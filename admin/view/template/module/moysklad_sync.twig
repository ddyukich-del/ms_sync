{{ header }}{{ column_left }}
<div id="content">
  <style id="moysklad-sync-products-style">
    .moysklad-products-toolbar { background: #f8fafc; border: 1px solid #dbe3ea; border-radius: 8px; padding: 14px; }
    .moysklad-products-toolbar .form-label { font-size: 12px; font-weight: 600; color: #334155; margin-bottom: 4px; }
    .moysklad-sort-presets { margin: -2px 0 14px 0; padding: 10px 12px; border: 1px solid #e5edf5; border-radius: 8px; background: #f8fafc; }
    .moysklad-sort-presets .btn { margin: 0 6px 6px 0; }
    .moysklad-products-summary { display: grid; grid-template-columns: repeat(4, minmax(140px, 1fr)); gap: 10px; margin-bottom: 12px; }
    .moysklad-products-summary .summary-item { border: 1px solid #dbe3ea; border-radius: 8px; padding: 10px 12px; background: #fff; }
    .moysklad-products-summary .summary-label { font-size: 12px; color: #64748b; }
    .moysklad-products-summary .summary-value { font-size: 20px; font-weight: 700; color: #0f172a; }
    .moysklad-products-table thead th { position: sticky; top: 0; z-index: 1; background: #f8fafc; vertical-align: middle; }
    .moysklad-products-table tbody tr:hover { background: #f1f5f9; }
    .moysklad-product-name { max-width: 420px; }
    .moysklad-muted-small { font-size: 12px; color: #64748b; }
    .moysklad-number { font-variant-numeric: tabular-nums; font-weight: 600; }
    @media (max-width: 991px) { .moysklad-products-summary { grid-template-columns: repeat(2, minmax(140px, 1fr)); } }
  </style>
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        <button type="submit" form="form-module" data-bs-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa-solid fa-save"></i></button>
        <a href="{{ back }}" data-bs-toggle="tooltip" title="{{ button_back }}" class="btn btn-light"><i class="fa-solid fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ol class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>

  <div class="container-fluid">
    <div id="moysklad-alerts"></div>

    <div class="card">
      <div class="card-header"><i class="fa-solid fa-gear"></i> {{ text_edit }}</div>
      <div class="card-body">
        <ul class="nav nav-tabs" id="moysklad-tabs" role="tablist">
          <li class="nav-item" role="presentation"><button class="nav-link active" id="tab-settings" data-bs-toggle="tab" data-bs-target="#pane-settings" type="button" role="tab">{{ text_tab_settings }}</button></li>
          <li class="nav-item" role="presentation"><button class="nav-link" id="tab-sync" data-bs-toggle="tab" data-bs-target="#pane-sync" type="button" role="tab">{{ text_tab_sync }}</button></li>
          <li class="nav-item" role="presentation"><button class="nav-link" id="tab-products" data-bs-toggle="tab" data-bs-target="#pane-products" type="button" role="tab">{{ text_tab_products }}</button></li>
          <li class="nav-item" role="presentation"><button class="nav-link" id="tab-logs" data-bs-toggle="tab" data-bs-target="#pane-logs" type="button" role="tab">{{ text_tab_logs }}</button></li>
        </ul>

        <div class="tab-content pt-3">
          <div class="tab-pane fade show active" id="pane-settings" role="tabpanel">
            <form id="form-module" action="{{ save }}" method="post" data-oc-toggle="ajax">
              <fieldset>
                <legend>{{ text_tab_settings }}</legend>

                <div class="row mb-3">
                  <label class="col-sm-3 col-form-label" for="input-status">{{ entry_status }}</label>
                  <div class="col-sm-9">
                    <div class="form-check form-switch form-switch-lg">
                      <input type="hidden" name="module_moysklad_sync_status" value="0"/>
                      <input type="checkbox" name="module_moysklad_sync_status" value="1" id="input-status" class="form-check-input"{% if module_moysklad_sync_status %} checked{% endif %}/>
                    </div>
                  </div>
                </div>

                <div class="row mb-3">
                  <label class="col-sm-3 col-form-label" for="input-api-token">{{ entry_api_token }}</label>
                  <div class="col-sm-9">
                    <input type="password" name="module_moysklad_sync_api_token" value="" placeholder="{% if module_moysklad_sync_api_token_set %}••••••••••••••••{% endif %}" id="input-api-token" class="form-control" autocomplete="new-password"/>
                    <div class="form-text">{{ help_api_token }}</div>
                    <div class="mt-2 d-flex flex-wrap gap-2">
                      <button type="button" id="button-test-connection" class="btn btn-light"><i class="fa-solid fa-plug-circle-check"></i> {{ button_test_connection }}</button>
                      <button type="button" id="button-load-dictionaries" class="btn btn-light"><i class="fa-solid fa-cloud-arrow-down"></i> {{ button_load_dictionaries }}</button>
                    </div>
                    <div class="form-text">{{ help_dictionaries }}</div>
                  </div>
                </div>

                <div class="row mb-3">
                  <label class="col-sm-3 col-form-label" for="input-warehouse-id">{{ entry_warehouse_id }}</label>
                  <div class="col-sm-9">
                    <select name="module_moysklad_sync_warehouse_ids[]" id="input-warehouse-id" class="form-select" multiple size="6">
                      {% for warehouse_id in module_moysklad_sync_warehouse_ids %}
                        {% set warehouse_name = module_moysklad_sync_warehouse_names[loop.index0] ?? '' %}
                        <option value="{{ warehouse_id }}" selected>{{ warehouse_name ?: text_current_value ~ ': ' ~ warehouse_id }}</option>
                      {% endfor %}
                    </select>
                    <div id="warehouse-names-hidden"></div>
                    <div class="form-text">{{ help_warehouse_id }}</div>
                  </div>
                </div>

                <div class="row mb-3">
                  <label class="col-sm-3 col-form-label" for="input-price-type-id">{{ entry_price_type_id }}</label>
                  <div class="col-sm-9">
                    <input type="hidden" name="module_moysklad_sync_price_type_name" id="input-price-type-name" value="{{ module_moysklad_sync_price_type_name }}"/>
                    <select name="module_moysklad_sync_price_type_id" id="input-price-type-id" class="form-select">
                      <option value="">{{ text_select_price_type }}</option>
                      {% if module_moysklad_sync_price_type_id %}
                        <option value="{{ module_moysklad_sync_price_type_id }}" selected>{{ module_moysklad_sync_price_type_name ?: text_current_value ~ ': ' ~ module_moysklad_sync_price_type_id }}</option>
                      {% endif %}
                    </select>
                    <div class="form-text">{{ help_price_type_id }}</div>
                  </div>
                </div>


                <div class="row mb-3">
                  <label class="col-sm-3 col-form-label" for="input-purchase-orders-enabled">{{ entry_purchase_orders_enabled }}</label>
                  <div class="col-sm-9">
                    <div class="form-check form-switch form-switch-lg">
                      <input type="hidden" name="module_moysklad_sync_purchase_orders_enabled" value="0"/>
                      <input type="checkbox" name="module_moysklad_sync_purchase_orders_enabled" value="1" id="input-purchase-orders-enabled" class="form-check-input"{% if module_moysklad_sync_purchase_orders_enabled %} checked{% endif %}/>
                    </div>
                    <div class="form-text">{{ help_purchase_orders_enabled }}</div>
                  </div>
                </div>

                <div class="row mb-3">
                  <label class="col-sm-3 col-form-label" for="input-purchase-order-state-ids">{{ entry_purchase_order_states }}</label>
                  <div class="col-sm-9">
                    <select name="module_moysklad_sync_purchase_order_state_ids[]" id="input-purchase-order-state-ids" class="form-select" multiple size="6">
                      {% for state_id in module_moysklad_sync_purchase_order_state_ids %}
                        <option value="{{ state_id }}" selected>{{ text_current_value }}: {{ state_id }}</option>
                      {% endfor %}
                    </select>
                    <div class="form-text">{{ help_purchase_order_states }}</div>
                  </div>
                </div>

                <div class="row mb-3">
                  <label class="col-sm-3 col-form-label" for="input-incoming-quantity-mode">{{ entry_incoming_quantity_mode }}</label>
                  <div class="col-sm-9">
                    <select name="module_moysklad_sync_incoming_quantity_mode" id="input-incoming-quantity-mode" class="form-select">
                      {% for value, title in incoming_quantity_mode_options %}
                        <option value="{{ value }}"{% if value == module_moysklad_sync_incoming_quantity_mode %} selected{% endif %}>{{ title }}</option>
                      {% endfor %}
                    </select>
                    <div class="form-text">{{ help_incoming_quantity_mode }}</div>
                  </div>
                </div>

                <div class="row mb-3">
                  <label class="col-sm-3 col-form-label" for="input-incoming-product-match-mode">{{ entry_incoming_product_match_mode }}</label>
                  <div class="col-sm-9">
                    <select name="module_moysklad_sync_incoming_product_match_mode" id="input-incoming-product-match-mode" class="form-select">
                      {% for value, title in incoming_product_match_mode_options %}
                        <option value="{{ value }}"{% if value == module_moysklad_sync_incoming_product_match_mode %} selected{% endif %}>{{ title }}</option>
                      {% endfor %}
                    </select>
                    <div class="form-text">{{ help_incoming_product_match_mode }}</div>
                  </div>
                </div>

                <div class="row mb-3">
                  <label class="col-sm-3 col-form-label" for="input-incoming-stock-status-id">{{ entry_incoming_stock_status_id }}</label>
                  <div class="col-sm-9">
                    <select name="module_moysklad_sync_incoming_stock_status_id" id="input-incoming-stock-status-id" class="form-select">
                      <option value="0">{{ text_current_value }}: {{ module_moysklad_sync_incoming_stock_status_id }}</option>
                      {% for stock_status_id, stock_status_name in stock_status_options %}
                        <option value="{{ stock_status_id }}"{% if stock_status_id == module_moysklad_sync_incoming_stock_status_id %} selected{% endif %}>{{ stock_status_name }}</option>
                      {% endfor %}
                    </select>
                    <div class="form-text">{{ help_incoming_stock_status_id }}</div>
                  </div>
                </div>

                <div class="row mb-3">
                  <label class="col-sm-3 col-form-label" for="input-missing-product-action">{{ entry_missing_product_action }}</label>
                  <div class="col-sm-9">
                    <select name="module_moysklad_sync_missing_product_action" id="input-missing-product-action" class="form-select">
                      {% for value, title in action_options %}
                        <option value="{{ value }}"{% if value == module_moysklad_sync_missing_product_action %} selected{% endif %}>{{ title }}</option>
                      {% endfor %}
                    </select>
                  </div>
                </div>

                <div class="row mb-3">
                  <label class="col-sm-3 col-form-label" for="input-missing-category-action">{{ entry_missing_category_action }}</label>
                  <div class="col-sm-9">
                    <select name="module_moysklad_sync_missing_category_action" id="input-missing-category-action" class="form-select">
                      {% for value, title in action_options %}
                        <option value="{{ value }}"{% if value == module_moysklad_sync_missing_category_action %} selected{% endif %}>{{ title }}</option>
                      {% endfor %}
                    </select>
                  </div>
                </div>

                <div class="row mb-3">
                  <label class="col-sm-3 col-form-label" for="input-zero-stock-action">{{ entry_zero_stock_action }}</label>
                  <div class="col-sm-9">
                    <select name="module_moysklad_sync_zero_stock_action" id="input-zero-stock-action" class="form-select">
                      {% for value, title in action_options %}
                        <option value="{{ value }}"{% if value == module_moysklad_sync_zero_stock_action %} selected{% endif %}>{{ title }}</option>
                      {% endfor %}
                    </select>
                  </div>
                </div>

                <div class="row mb-3">
                  <label class="col-sm-3 col-form-label" for="input-seo-mode">{{ entry_seo_mode }}</label>
                  <div class="col-sm-9">
                    <select name="module_moysklad_sync_seo_mode" id="input-seo-mode" class="form-select">
                      {% for value, title in seo_mode_options %}
                        <option value="{{ value }}"{% if value == module_moysklad_sync_seo_mode %} selected{% endif %}>{{ title }}</option>
                      {% endfor %}
                    </select>
                  </div>
                </div>

                <div class="row mb-3">
                  <label class="col-sm-3 col-form-label" for="input-clear-empty-description">{{ entry_clear_empty_description }}</label>
                  <div class="col-sm-9">
                    <div class="form-check form-switch form-switch-lg">
                      <input type="hidden" name="module_moysklad_sync_clear_empty_description" value="0"/>
                      <input type="checkbox" name="module_moysklad_sync_clear_empty_description" value="1" id="input-clear-empty-description" class="form-check-input"{% if module_moysklad_sync_clear_empty_description %} checked{% endif %}/>
                    </div>
                  </div>
                </div>

                <hr/>

                <div class="row mb-3">
                  <label class="col-sm-3 col-form-label" for="input-category-batch">{{ entry_category_batch_size }}</label>
                  <div class="col-sm-9">
                    <input type="number" min="1" max="500" name="module_moysklad_sync_category_batch_size" value="{{ module_moysklad_sync_category_batch_size }}" id="input-category-batch" class="form-control"/>
                  </div>
                </div>

                <div class="row mb-3">
                  <label class="col-sm-3 col-form-label" for="input-product-batch">{{ entry_product_batch_size }}</label>
                  <div class="col-sm-9">
                    <input type="number" min="1" max="200" name="module_moysklad_sync_product_batch_size" value="{{ module_moysklad_sync_product_batch_size }}" id="input-product-batch" class="form-control"/>
                  </div>
                </div>

                <div class="row mb-3">
                  <label class="col-sm-3 col-form-label" for="input-stock-batch">{{ entry_stock_batch_size }}</label>
                  <div class="col-sm-9">
                    <input type="number" min="1" max="500" name="module_moysklad_sync_stock_batch_size" value="{{ module_moysklad_sync_stock_batch_size }}" id="input-stock-batch" class="form-control"/>
                  </div>
                </div>

                <div class="row mb-3">
                  <label class="col-sm-3 col-form-label" for="input-image-batch">{{ entry_image_batch_size }}</label>
                  <div class="col-sm-9">
                    <input type="number" min="1" max="50" name="module_moysklad_sync_image_batch_size" value="{{ module_moysklad_sync_image_batch_size }}" id="input-image-batch" class="form-control"/>
                    <div class="form-text">{{ help_batches }}</div>
                  </div>
                </div>

                <div class="row mb-3">
                  <label class="col-sm-3 col-form-label" for="input-max-images-per-product">{{ entry_max_images_per_product }}</label>
                  <div class="col-sm-9">
                    <input type="number" min="1" max="20" name="module_moysklad_sync_max_images_per_product" value="{{ module_moysklad_sync_max_images_per_product }}" id="input-max-images-per-product" class="form-control"/>
                    <div class="form-text">{{ help_images_limits }}</div>
                  </div>
                </div>

                <div class="row mb-3">
                  <label class="col-sm-3 col-form-label" for="input-max-image-bytes">{{ entry_max_image_bytes }}</label>
                  <div class="col-sm-9">
                    <input type="number" min="1048576" max="31457280" name="module_moysklad_sync_max_image_bytes" value="{{ module_moysklad_sync_max_image_bytes }}" id="input-max-image-bytes" class="form-control"/>
                  </div>
                </div>

                <div class="row mb-3">
                  <label class="col-sm-3 col-form-label" for="input-log-level">{{ entry_log_level }}</label>
                  <div class="col-sm-9">
                    <select name="module_moysklad_sync_log_level" id="input-log-level" class="form-select">
                      {% for value, title in log_level_options %}
                        <option value="{{ value }}"{% if value == module_moysklad_sync_log_level %} selected{% endif %}>{{ title }}</option>
                      {% endfor %}
                    </select>
                  </div>
                </div>
              </fieldset>
            </form>
          </div>

          <div class="tab-pane fade" id="pane-sync" role="tabpanel">
            <div class="alert alert-info"><i class="fa-solid fa-circle-info"></i> {{ text_stage3_notice }}</div>

            <div class="d-flex flex-wrap gap-2 mb-3">
              <button type="button" class="btn btn-primary" id="button-start-import"><i class="fa-solid fa-download"></i> {{ button_import }}</button>
              <button type="button" class="btn btn-warning" id="button-start-stock"><i class="fa-solid fa-boxes-stacked"></i> {{ button_stock }}</button>
              <button type="button" class="btn btn-success" id="button-start-images"><i class="fa-solid fa-image"></i> {{ button_images }}</button>
              <button type="button" class="btn btn-danger" id="button-stop-task"><i class="fa-solid fa-stop"></i> {{ button_stop_task }}</button>
              <button type="button" class="btn btn-light" id="button-refresh-status"><i class="fa-solid fa-rotate"></i> {{ button_refresh_status }}</button>
              <button type="button" class="btn btn-light" id="button-test-connection-sync"><i class="fa-solid fa-plug-circle-check"></i> {{ button_test_connection }}</button>
            </div>

            <div class="card border-secondary">
              <div class="card-header"><i class="fa-solid fa-list-check"></i> {{ text_task_panel_title }}</div>
              <div class="card-body" id="task-panel">
                <div class="alert alert-secondary mb-0">{{ text_task_panel_empty }}</div>
              </div>
            </div>
          </div>

          <div class="tab-pane fade" id="pane-products" role="tabpanel">
            <div class="d-flex justify-content-between align-items-center mb-2">
              <h3 class="mb-0">{{ text_products_status_title }}</h3>
              <div class="d-flex gap-2">
                <button type="button" class="btn btn-success btn-sm" id="button-export-products"><i class="fa-solid fa-file-csv"></i> {{ button_export_products }}</button>
                <button type="button" class="btn btn-light btn-sm" id="button-refresh-products"><i class="fa-solid fa-rotate"></i> {{ button_refresh_status }}</button>
              </div>
            </div>
            <div class="alert alert-info"><i class="fa-solid fa-circle-info"></i> {{ text_products_status_help }}</div>

            <div class="card mb-3 border-0 shadow-sm">
              <div class="card-header bg-light d-flex justify-content-between align-items-center">
                <strong><i class="fa-solid fa-sliders"></i> {{ text_products_filters_title }}</strong>
                <span class="small text-muted">{{ text_products_filters_help }}</span>
              </div>
              <div class="card-body moysklad-products-toolbar">
                <div class="row g-3 align-items-end">
                  <div class="col-lg-3 col-md-6">
                    <label class="form-label" for="product-filter-search">{{ entry_product_filter_search }}</label>
                    <input type="text" id="product-filter-search" class="form-control" placeholder="Название, артикул, заказ"/>
                  </div>
                  <div class="col-lg-2 col-md-6">
                    <label class="form-label" for="product-filter-source">{{ entry_product_filter_source }}</label>
                    <select id="product-filter-source" class="form-select">
                      <option value="">{{ text_all }}</option>
                      <option value="stock">{{ text_product_source_stock }}</option>
                      <option value="incoming">{{ text_product_source_incoming }}</option>
                      <option value="stock_incoming">{{ text_product_source_stock_incoming }}</option>
                      <option value="missing">{{ text_product_source_missing }}</option>
                    </select>
                  </div>
                  <div class="col-lg-2 col-md-6">
                    <label class="form-label" for="product-filter-status">{{ entry_product_filter_status }}</label>
                    <select id="product-filter-status" class="form-select">
                      <option value="">{{ text_all }}</option>
                      <option value="enabled">{{ text_status_enabled }}</option>
                      <option value="disabled">{{ text_status_disabled }}</option>
                    </select>
                  </div>
                  <div class="col-lg-2 col-md-6">
                    <label class="form-label" for="product-filter-quantity">{{ entry_product_filter_quantity }}</label>
                    <select id="product-filter-quantity" class="form-select">
                      <option value="">{{ text_all }}</option>
                      <option value="positive">{{ text_quantity_positive }}</option>
                      <option value="zero">{{ text_quantity_zero }}</option>
                    </select>
                  </div>
                  <div class="col-lg-2 col-md-6">
                    <label class="form-label" for="product-filter-expected">{{ entry_product_filter_expected }}</label>
                    <select id="product-filter-expected" class="form-select">
                      <option value="">{{ text_all }}</option>
                      <option value="positive">{{ text_expected_positive }}</option>
                      <option value="zero">{{ text_expected_zero }}</option>
                    </select>
                  </div>
                  <div class="col-lg-1 col-md-6">
                    <label class="form-label" for="product-filter-limit">{{ entry_product_limit }}</label>
                    <select id="product-filter-limit" class="form-select">
                      <option value="50">50</option>
                      <option value="150" selected>150</option>
                      <option value="300">300</option>
                      <option value="500">500</option>
                    </select>
                  </div>
                  <div class="col-lg-3 col-md-6">
                    <label class="form-label" for="product-filter-order-state">{{ entry_product_filter_order_state }}</label>
                    <input type="text" id="product-filter-order-state" class="form-control" placeholder="ПРЕДЗАКАЗ"/>
                  </div>
                  <div class="col-lg-3 col-md-6">
                    <label class="form-label" for="product-sort">{{ entry_product_sort }}</label>
                    <select id="product-sort" class="form-select">
                      <option value="product" selected>{{ text_sort_by_product }}</option>
                      <option value="article">{{ text_sort_by_article }}</option>
                      <option value="source">{{ text_sort_by_source }}</option>
                      <option value="quantity">{{ text_sort_by_quantity }}</option>
                      <option value="expected">{{ text_sort_by_expected }}</option>
                      <option value="stock_status">{{ text_sort_by_stock_status }}</option>
                      <option value="purchase_order">{{ text_sort_by_purchase_order }}</option>
                      <option value="updated">{{ text_sort_by_updated }}</option>
                    </select>
                  </div>
                  <div class="col-lg-3 col-md-6">
                    <label class="form-label" for="product-order">{{ entry_product_order }}</label>
                    <select id="product-order" class="form-select">
                      <option value="ASC">{{ text_order_asc }}</option>
                      <option value="DESC">{{ text_order_desc }}</option>
                    </select>
                  </div>
                  <div class="col-lg-3 col-md-6 d-flex gap-2">
                    <button type="button" class="btn btn-primary flex-fill" id="button-apply-product-filter"><i class="fa-solid fa-filter"></i> {{ button_apply_filter }}</button>
                    <button type="button" class="btn btn-light" id="button-reset-product-filter"><i class="fa-solid fa-xmark"></i> {{ button_reset_filter }}</button>
                  </div>
                </div>

              </div>
            </div>

            <div id="products-status-panel" class="table-responsive">
              <div class="alert alert-secondary">{{ text_no_products_status }}</div>
            </div>
          </div>

          <div class="tab-pane fade" id="pane-logs" role="tabpanel">
            <h3>{{ text_logs_latest }}</h3>
            <div id="logs-panel" class="table-responsive">
              <div class="alert alert-secondary">{{ text_no_logs }}</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
(function () {
  'use strict';

  const form = document.getElementById('form-module');
  const alerts = document.getElementById('moysklad-alerts');
  const testButtons = [document.getElementById('button-test-connection'), document.getElementById('button-test-connection-sync')].filter(Boolean);
  const loadButton = document.getElementById('button-load-dictionaries');
  const warehouseSelect = document.getElementById('input-warehouse-id');
  const warehouseNamesHidden = document.getElementById('warehouse-names-hidden');
  const priceTypeSelect = document.getElementById('input-price-type-id');
  const priceTypeName = document.getElementById('input-price-type-name');
  const purchaseOrderStatesSelect = document.getElementById('input-purchase-order-state-ids');
  const startImportButton = document.getElementById('button-start-import');
  const startStockButton = document.getElementById('button-start-stock');
  const startImagesButton = document.getElementById('button-start-images');
  const stopTaskButton = document.getElementById('button-stop-task');
  const refreshStatusButton = document.getElementById('button-refresh-status');
  const taskPanel = document.getElementById('task-panel');
  const logsPanel = document.getElementById('logs-panel');
  const productsStatusPanel = document.getElementById('products-status-panel');
  const refreshProductsButton = document.getElementById('button-refresh-products');
  const exportProductsButton = document.getElementById('button-export-products');
  const productFilterSearch = document.getElementById('product-filter-search');
  const productFilterSource = document.getElementById('product-filter-source');
  const productFilterStatus = document.getElementById('product-filter-status');
  const productFilterQuantity = document.getElementById('product-filter-quantity');
  const productFilterExpected = document.getElementById('product-filter-expected');
  const productFilterOrderState = document.getElementById('product-filter-order-state');
  const productFilterLimit = document.getElementById('product-filter-limit');
  const productSort = document.getElementById('product-sort');
  const productOrder = document.getElementById('product-order');
  const applyProductFilterButton = document.getElementById('button-apply-product-filter');
  const resetProductFilterButton = document.getElementById('button-reset-product-filter');
  let taskLoopRunning = false;

  // Важно: AJAX-URL собираем на стороне браузера из текущего URL страницы.
  // Почему не подставляем готовые ссылки из PHP? В OpenCart url->link() часто
  // возвращает ссылки с HTML-сущностями (&amp;). Внутри JavaScript такая строка
  // может уйти на сервер как amp;user_token вместо user_token, и админка отдаст
  // страницу Авторизация вместо JSON. Current location уже содержит реальный
  // user_token текущей сессии без HTML-экранирования.
  function ajaxUrl(action) {
    const url = new URL(window.location.href);
    url.searchParams.set('ajax_action', action);
    return url.toString();
  }

  function productStatusesUrl() {
    const url = new URL(ajaxUrl('get_product_statuses'));

    const setParam = function (name, element) {
      if (!element) {
        return;
      }

      const value = (element.value || '').trim();

      if (value !== '') {
        url.searchParams.set(name, value);
      }
    };

    setParam('filter_search', productFilterSearch);
    setParam('filter_source', productFilterSource);
    setParam('filter_status', productFilterStatus);
    setParam('filter_quantity', productFilterQuantity);
    setParam('filter_expected', productFilterExpected);
    setParam('filter_order_state', productFilterOrderState);
    setParam('limit', productFilterLimit);
    setParam('sort', productSort);
    setParam('order', productOrder);

    return url.toString();
  }

  function productExportUrl() {
    const url = new URL(productStatusesUrl());
    url.searchParams.set('ajax_action', 'export_product_statuses');
    url.searchParams.set('export_limit', '10000');
    return url.toString();
  }

  function showAlert(type, message) {
    alerts.innerHTML = '<div class="alert alert-' + type + ' alert-dismissible">'
      + '<i class="fa-solid fa-circle-info"></i> ' + escapeHtml(message)
      + '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>'
      + '</div>';
  }

  function escapeHtml(value) {
    return String(value).replace(/[&<>"']/g, function (char) {
      return {'&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;'}[char];
    });
  }

  function setLoading(button, isLoading) {
    if (!button) {
      return;
    }

    if (isLoading) {
      button.dataset.originalText = button.innerHTML;
      button.disabled = true;
      button.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> {{ text_loading|e('js') }}';
    } else {
      button.disabled = false;
      button.innerHTML = button.dataset.originalText || button.innerHTML;
    }
  }

  async function post(url) {
    const response = await fetch(url, {
      method: 'POST',
      credentials: 'same-origin',
      body: new FormData(form)
    });

    // Не вызываем response.json() напрямую. Если сервер вернул HTML
    // (например, страницу логина, отказ прав или PHP-ошибку), браузер иначе покажет
    // непонятное Unexpected token '<'. Так мы даем администратору нормальную подсказку.
    const text = await response.text();

    try {
      return JSON.parse(text);
    } catch (e) {
      console.error('Moysklad Sync: non-JSON response', text);
      return {
        error: 'Сервер вернул не JSON. Чаще всего это страница авторизации, отказ прав или PHP-ошибка. Проверьте system/storage/logs/error.log. Начало ответа: ' + text.substring(0, 120)
      };
    }
  }

  async function testConnection(button) {
    setLoading(button, true);

    try {
      const json = await post(ajaxUrl('test_connection'));

      if (json.error) {
        showAlert('danger', json.error);
      } else {
        const company = json.company_name ? ' ' + json.company_name : '';
        showAlert('success', json.success + company);
      }
    } catch (error) {
      showAlert('danger', error.message);
    } finally {
      setLoading(button, false);
    }
  }

  async function loadDictionaries() {
    setLoading(loadButton, true);

    try {
      const json = await post(ajaxUrl('load_dictionaries'));

      if (json.error) {
        showAlert('danger', json.error);
        return;
      }

      fillMultiSelect(warehouseSelect, json.warehouses || []);
      updateWarehouseNamesHidden();
      fillSelect(priceTypeSelect, priceTypeName, json.price_types || [], '{{ text_select_price_type|e('js') }}');
      fillMultiSelect(purchaseOrderStatesSelect, json.purchase_order_states || []);
      showAlert('success', json.success);
    } catch (error) {
      showAlert('danger', error.message);
    } finally {
      setLoading(loadButton, false);
    }
  }

  function fillSelect(select, hiddenNameInput, items, emptyText) {
    const currentValue = select.value;

    select.innerHTML = '';
    select.appendChild(new Option(emptyText, ''));

    items.forEach(function (item) {
      const suffix = item.archived ? ' [архив]' : '';
      const option = new Option(item.name + suffix, item.id);
      option.dataset.name = item.name;
      select.appendChild(option);
    });

    if (currentValue) {
      select.value = currentValue;
    }

    updateSelectedName(select, hiddenNameInput);
  }


  function fillMultiSelect(select, items) {
    if (!select) {
      return;
    }

    const selectedValues = Array.from(select.selectedOptions).map(function (option) { return option.value; });
    const seen = {};
    select.innerHTML = '';

    items.forEach(function (item) {
      const suffix = item.archived ? ' [архив]' : '';
      const option = new Option((item.name || item.id) + suffix, item.id);
      option.dataset.name = item.name || item.id;
      option.selected = selectedValues.indexOf(item.id) !== -1;
      seen[item.id] = true;
      select.appendChild(option);
    });

    selectedValues.forEach(function (value) {
      if (!seen[value]) {
        const option = new Option('{{ text_current_value|e('js') }}: ' + value, value);
        option.selected = true;
        select.appendChild(option);
      }
    });
  }

  function updateSelectedName(select, hiddenNameInput) {
    const option = select.options[select.selectedIndex];
    hiddenNameInput.value = option && option.value ? (option.dataset.name || option.text) : '';
  }

  function updateWarehouseNamesHidden() {
    if (!warehouseSelect || !warehouseNamesHidden) {
      return;
    }

    warehouseNamesHidden.innerHTML = '';
    Array.from(warehouseSelect.selectedOptions).forEach(function (option) {
      const input = document.createElement('input');
      input.type = 'hidden';
      input.name = 'module_moysklad_sync_warehouse_names[]';
      input.value = option.dataset.name || option.text || '';
      warehouseNamesHidden.appendChild(input);
    });
  }


  async function startTask(url, button) {
    setLoading(button, true);

    try {
      const json = await post(url);
      handleTaskResponse(json);

      if (!json.error) {
        runTaskLoop();
      }
    } catch (error) {
      showAlert('danger', error.message);
    } finally {
      setLoading(button, false);
    }
  }

  async function runTaskLoop() {
    if (taskLoopRunning) {
      return;
    }

    taskLoopRunning = true;

    try {
      while (true) {
        const json = await post(ajaxUrl('run_task_step'));
        handleTaskResponse(json);

        if (json.error || !json.task || !json.task.is_active) {
          break;
        }

        // Небольшая пауза разгружает слабый сервер: браузер не шлет десятки
        // AJAX-запросов подряд без передышки, а PHP успевает освободить ресурсы.
        await new Promise(function (resolve) { setTimeout(resolve, 350); });
      }
    } catch (error) {
      showAlert('danger', error.message);
    } finally {
      taskLoopRunning = false;
    }
  }

  async function refreshStatus() {
    setLoading(refreshStatusButton, true);

    try {
      const json = await post(ajaxUrl('get_task_status'));
      handleTaskResponse(json);
    } catch (error) {
      showAlert('danger', error.message);
    } finally {
      setLoading(refreshStatusButton, false);
    }
  }

  async function stopTask() {
    setLoading(stopTaskButton, true);

    try {
      const json = await post(ajaxUrl('stop_task'));
      handleTaskResponse(json);
    } catch (error) {
      showAlert('danger', error.message);
    } finally {
      setLoading(stopTaskButton, false);
    }
  }

  function handleTaskResponse(json) {
    if (json.error) {
      showAlert('danger', json.error);
    } else if (json.success) {
      showAlert('success', json.success);
    }

    if (json.task) {
      renderTask(json.task);
    }

    if (json.logs) {
      renderLogs(json.logs);
    }

    if (json.product_statuses) {
      renderProductStatuses(json.product_statuses);
    }
  }

  function renderTask(task) {
    if (!task || !task.task_id) {
      taskPanel.innerHTML = '<div class="alert alert-secondary mb-0">{{ text_task_panel_empty|e('js') }}</div>';
      return;
    }

    const statusClass = task.is_active ? 'primary' : (task.status === 'failed' ? 'danger' : 'success');

    taskPanel.innerHTML = ''
      + '<div class="row g-3">'
      + '<div class="col-md-4"><strong>ID:</strong> #' + escapeHtml(task.task_id) + '</div>'
      + '<div class="col-md-4"><strong>Тип:</strong> ' + escapeHtml(task.task_type_title) + '</div>'
      + '<div class="col-md-4"><strong>Статус:</strong> <span class="badge text-bg-' + statusClass + '">' + escapeHtml(task.status_title) + '</span></div>'
      + '<div class="col-md-12"><strong>Шаг:</strong> ' + escapeHtml(task.current_step_title) + '</div>'
      + '</div>'
      + '<hr/>'
      + '<div class="row g-2 text-center">'
      + counterHtml('{{ text_counter_processed|e('js') }}', task.processed_items)
      + counterHtml('{{ text_counter_created|e('js') }}', task.created_items)
      + counterHtml('{{ text_counter_updated|e('js') }}', task.updated_items)
      + counterHtml('{{ text_counter_skipped|e('js') }}', task.skipped_items)
      + counterHtml('{{ text_counter_disabled|e('js') }}', task.disabled_items)
      + counterHtml('{{ text_counter_deleted|e('js') }}', task.deleted_items)
      + counterHtml('{{ text_counter_errors|e('js') }}', task.error_items)
      + '</div>'
      + (task.last_error ? '<div class="alert alert-danger mt-3 mb-0">' + escapeHtml(task.last_error) + '</div>' : '');
  }

  function counterHtml(title, value) {
    return '<div class="col-6 col-md"><div class="border rounded p-2"><div class="small text-muted">' + escapeHtml(title) + '</div><div class="fs-5">' + escapeHtml(value || 0) + '</div></div></div>';
  }

  async function refreshProductStatuses() {
    setLoading(refreshProductsButton, true);

    try {
      const json = await post(productStatusesUrl());

      if (json.error) {
        showAlert('danger', json.error);
        return;
      }

      renderProductStatuses(json.product_statuses || []);
    } catch (error) {
      showAlert('danger', error.message);
    } finally {
      setLoading(refreshProductsButton, false);
    }
  }

  function renderProductStatuses(rows) {
    if (!productsStatusPanel) {
      return;
    }

    if (!rows || !rows.length) {
      productsStatusPanel.innerHTML = '<div class="alert alert-secondary">{{ text_no_products_status|e('js') }}</div>';
      return;
    }

    const sortButton = function (key, title) {
      const active = productSort && productSort.value === key;
      const icon = active ? (productOrder && productOrder.value === 'DESC' ? ' ↓' : ' ↑') : '';
      return '<button type="button" class="btn btn-link p-0 product-sort-link" data-sort="' + escapeHtml(key) + '">' + escapeHtml(title) + icon + '</button>';
    };

    let totalQuantity = 0;
    let totalExpected = 0;
    let incomingCount = 0;
    let stockCount = 0;

    rows.forEach(function (row) {
      totalQuantity += Number(row.quantity || 0);
      totalExpected += Number(row.expected_quantity || row.incoming_quantity || 0);

      if (row.sync_source === 'incoming' || row.sync_source === 'stock_incoming') {
        incomingCount++;
      }

      if (row.sync_source === 'stock' || row.sync_source === 'stock_incoming') {
        stockCount++;
      }
    });

    let html = '<div class="moysklad-products-summary">'
      + '<div class="summary-item"><div class="summary-label">{{ text_summary_shown|e('js') }}</div><div class="summary-value">' + escapeHtml(rows.length) + '</div></div>'
      + '<div class="summary-item"><div class="summary-label">{{ text_summary_stock|e('js') }}</div><div class="summary-value">' + escapeHtml(stockCount) + '</div></div>'
      + '<div class="summary-item"><div class="summary-label">{{ text_summary_incoming|e('js') }}</div><div class="summary-value">' + escapeHtml(incomingCount) + '</div></div>'
      + '<div class="summary-item"><div class="summary-label">{{ text_summary_expected|e('js') }}</div><div class="summary-value">' + escapeHtml(totalExpected) + '</div></div>'
      + '</div>';

    html += '<div class="moysklad-sort-presets">'
      + '<div class="small fw-bold text-muted mb-2">{{ text_sort_presets|e('js') }}</div>'
      + '<button type="button" class="btn btn-outline-secondary btn-sm product-sort-preset" data-sort="product" data-order="ASC"><i class="fa-solid fa-arrow-down-a-z"></i> {{ text_sort_name_asc|e('js') }}</button>'
      + '<button type="button" class="btn btn-outline-secondary btn-sm product-sort-preset" data-sort="product" data-order="DESC"><i class="fa-solid fa-arrow-up-z-a"></i> {{ text_sort_name_desc|e('js') }}</button>'
      + '<button type="button" class="btn btn-outline-secondary btn-sm product-sort-preset" data-sort="quantity" data-order="DESC"><i class="fa-solid fa-arrow-down-wide-short"></i> {{ text_sort_quantity_desc|e('js') }}</button>'
      + '<button type="button" class="btn btn-outline-secondary btn-sm product-sort-preset" data-sort="quantity" data-order="ASC"><i class="fa-solid fa-arrow-up-wide-short"></i> {{ text_sort_quantity_asc|e('js') }}</button>'
      + '<button type="button" class="btn btn-outline-secondary btn-sm product-sort-preset" data-sort="expected" data-order="DESC"><i class="fa-solid fa-truck-fast"></i> {{ text_sort_expected_desc|e('js') }}</button>'
      + '<button type="button" class="btn btn-outline-secondary btn-sm product-sort-preset" data-sort="expected" data-order="ASC"><i class="fa-solid fa-truck"></i> {{ text_sort_expected_asc|e('js') }}</button>'
      + '<button type="button" class="btn btn-outline-secondary btn-sm product-sort-preset" data-sort="updated" data-order="DESC"><i class="fa-solid fa-clock-rotate-left"></i> {{ text_sort_updated_desc|e('js') }}</button>'
      + '<button type="button" class="btn btn-outline-secondary btn-sm product-sort-preset" data-sort="updated" data-order="ASC"><i class="fa-regular fa-clock"></i> {{ text_sort_updated_asc|e('js') }}</button>'
      + '</div>';

    html += '<table class="table table-sm table-striped table-hover align-middle moysklad-products-table">'
      + '<thead><tr>'
      + '<th>' + sortButton('product', '{{ column_product|e('js') }}') + '</th>'
      + '<th>' + sortButton('article', '{{ column_article|e('js') }}') + '</th>'
      + '<th>' + sortButton('source', '{{ column_sync_source|e('js') }}') + '</th>'
      + '<th>' + sortButton('quantity', '{{ column_quantity|e('js') }}') + '</th>'
      + '<th>' + sortButton('expected', '{{ column_expected_quantity|e('js') }}') + '</th>'
      + '<th>' + sortButton('stock_status', '{{ column_stock_status|e('js') }}') + '</th>'
      + '<th>' + sortButton('purchase_order', '{{ column_purchase_order|e('js') }}') + '</th>'
      + '<th>' + sortButton('updated', '{{ column_updated|e('js') }}') + '</th>'
      + '</tr></thead><tbody>';

    rows.forEach(function (row) {
      const productState = Number(row.status || 0) === 1 ? '' : '<div class="small text-danger">{{ text_product_disabled|e('js') }}</div>';
      const expectedQuantity = (row.sync_source === 'incoming' || row.sync_source === 'stock_incoming') ? (row.expected_quantity || row.incoming_quantity || '0') : '—';
      const orderInfo = row.purchase_order_name
        ? escapeHtml(row.purchase_order_name) + (row.purchase_order_state_name ? '<div class="small text-muted">' + escapeHtml(row.purchase_order_state_name) + '</div>' : '')
        : '—';

      html += '<tr>'
        + '<td class="moysklad-product-name"><strong>' + escapeHtml(row.name || '') + '</strong><div class="moysklad-muted-small">ID: ' + escapeHtml(row.product_id || '') + '</div>' + productState + '</td>'
        + '<td>' + escapeHtml(row.article || '') + '</td>'
        + '<td><span class="badge text-bg-' + escapeHtml(row.sync_source_badge || 'secondary') + '">' + escapeHtml(row.sync_source_title || '') + '</span></td>'
        + '<td class="moysklad-number">' + escapeHtml(row.quantity || '0') + '</td>'
        + '<td class="moysklad-number">' + escapeHtml(expectedQuantity) + '</td>'
        + '<td>' + escapeHtml(row.stock_status_name || '') + '</td>'
        + '<td>' + orderInfo + '</td>'
        + '<td>' + escapeHtml(row.last_synced_at || '') + '</td>'
        + '</tr>';
    });

    html += '</tbody></table>';
    productsStatusPanel.innerHTML = html;

    productsStatusPanel.querySelectorAll('.product-sort-link').forEach(function (button) {
      button.addEventListener('click', function () {
        const nextSort = button.getAttribute('data-sort') || 'source';

        if (productSort && productOrder) {
          if (productSort.value === nextSort) {
            productOrder.value = productOrder.value === 'DESC' ? 'ASC' : 'DESC';
          } else {
            productSort.value = nextSort;
            productOrder.value = 'ASC';
          }
        }

        refreshProductStatuses();
      });
    });

    productsStatusPanel.querySelectorAll('.product-sort-preset').forEach(function (button) {
      button.addEventListener('click', function () {
        if (productSort) {
          productSort.value = button.getAttribute('data-sort') || 'product';
        }

        if (productOrder) {
          productOrder.value = button.getAttribute('data-order') || 'ASC';
        }

        refreshProductStatuses();
      });
    });
  }

  function renderLogs(logs) {
    if (!logs || !logs.length) {
      logsPanel.innerHTML = '<div class="alert alert-secondary">{{ text_no_logs|e('js') }}</div>';
      return;
    }

    let html = '<table class="table table-sm table-striped align-middle"><thead><tr><th>Дата</th><th>Уровень</th><th>Объект</th><th>Сообщение</th></tr></thead><tbody>';

    logs.forEach(function (log) {
      html += '<tr>'
        + '<td>' + escapeHtml(log.created_at) + '</td>'
        + '<td><span class="badge text-bg-secondary">' + escapeHtml(log.level) + '</span></td>'
        + '<td>' + escapeHtml(log.entity_type || '') + '</td>'
        + '<td>' + escapeHtml(log.message) + '</td>'
        + '</tr>';
    });

    html += '</tbody></table>';
    logsPanel.innerHTML = html;
  }

  warehouseSelect.addEventListener('change', updateWarehouseNamesHidden);

  priceTypeSelect.addEventListener('change', function () {
    updateSelectedName(priceTypeSelect, priceTypeName);
  });

  testButtons.forEach(function (button) {
    button.addEventListener('click', function () {
      testConnection(button);
    });
  });

  loadButton.addEventListener('click', loadDictionaries);

  startImportButton.addEventListener('click', function () { startTask(ajaxUrl('start_import'), startImportButton); });
  startStockButton.addEventListener('click', function () { startTask(ajaxUrl('start_stock_update'), startStockButton); });
  startImagesButton.addEventListener('click', function () { startTask(ajaxUrl('start_image_sync'), startImagesButton); });
  stopTaskButton.addEventListener('click', stopTask);
  refreshStatusButton.addEventListener('click', refreshStatus);
  if (refreshProductsButton) {
    refreshProductsButton.addEventListener('click', refreshProductStatuses);
  }

  if (exportProductsButton) {
    exportProductsButton.addEventListener('click', function () {
      window.location.href = productExportUrl();
    });
  }

  if (applyProductFilterButton) {
    applyProductFilterButton.addEventListener('click', refreshProductStatuses);
  }

  if (resetProductFilterButton) {
    resetProductFilterButton.addEventListener('click', function () {
      [productFilterSearch, productFilterSource, productFilterStatus, productFilterQuantity, productFilterExpected, productFilterOrderState].forEach(function (element) {
        if (element) {
          element.value = '';
        }
      });

      if (productFilterLimit) {
        productFilterLimit.value = '150';
      }

      if (productSort) {
        productSort.value = 'product';
      }

      if (productOrder) {
        productOrder.value = 'ASC';
      }

      refreshProductStatuses();
    });
  }

  [productFilterSource, productFilterStatus, productFilterQuantity, productFilterExpected, productFilterLimit, productSort, productOrder].forEach(function (element) {
    if (!element) {
      return;
    }

    element.addEventListener('change', refreshProductStatuses);
  });

  [productFilterSearch, productFilterOrderState].forEach(function (element) {
    if (!element) {
      return;
    }

    element.addEventListener('keydown', function (event) {
      if (event.key === 'Enter') {
        event.preventDefault();
        refreshProductStatuses();
      }
    });
  });

  updateWarehouseNamesHidden();
  refreshStatus();
})();
</script>
{{ footer }}
