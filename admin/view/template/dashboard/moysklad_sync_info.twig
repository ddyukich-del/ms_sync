<div class="card mb-3 moysklad-dashboard-card">
  <div class="card-header d-flex justify-content-between align-items-center">
    <span><i class="fa-solid fa-warehouse"></i> {{ heading_title }}</span>
    <a href="{{ products_url }}" class="btn btn-sm btn-primary"><i class="fa-solid fa-list"></i> {{ button_open_products }}</a>
  </div>
  <div class="card-body">
    <div class="row g-2 text-center">
      <div class="col-sm-6 col-lg-3">
        <div class="border rounded p-2 bg-light h-100">
          <div class="small text-muted">{{ text_total_products }}</div>
          <div class="fs-4 fw-bold">{{ total_products }}</div>
        </div>
      </div>
      <div class="col-sm-6 col-lg-3">
        <div class="border rounded p-2 bg-light h-100">
          <div class="small text-muted">{{ text_stock_products }}</div>
          <div class="fs-4 fw-bold text-success">{{ stock_products }}</div>
        </div>
      </div>
      <div class="col-sm-6 col-lg-3">
        <div class="border rounded p-2 bg-light h-100">
          <div class="small text-muted">{{ text_incoming_products }}</div>
          <div class="fs-4 fw-bold text-warning">{{ incoming_products }}</div>
        </div>
      </div>
      <div class="col-sm-6 col-lg-3">
        <div class="border rounded p-2 bg-light h-100">
          <div class="small text-muted">{{ text_expected_quantity }}</div>
          <div class="fs-4 fw-bold text-info">{{ expected_quantity }}</div>
        </div>
      </div>
    </div>
    <div class="d-flex flex-wrap justify-content-between align-items-center mt-3 gap-2">
      <div class="text-muted small">
        {{ text_last_sync }}: {{ last_synced_at ?: text_never }}
        {% if missing_products %}
          · {{ text_missing_products }}: {{ missing_products }}
        {% endif %}
      </div>
      <div class="btn-group btn-group-sm">
        <a href="{{ sync_url }}" class="btn btn-outline-primary"><i class="fa-solid fa-rotate"></i> {{ button_open_sync }}</a>
        <a href="{{ autosync_url }}" class="btn btn-outline-success"><i class="fa-solid fa-clock-rotate-left"></i> {{ button_open_autosync }}</a>
        <a href="{{ diagnostics_url }}" class="btn btn-outline-warning"><i class="fa-solid fa-stethoscope"></i> {{ button_open_diagnostics }}</a>
        <a href="{{ settings_url }}" class="btn btn-outline-secondary"><i class="fa-solid fa-gear"></i> {{ button_open_settings }}</a>
      </div>
    </div>
  </div>
</div>
